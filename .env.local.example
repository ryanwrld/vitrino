# Supabase (projeto de produção/dev) — Dashboard -> Project Settings -> API
# (ou saída de `supabase start` para o ambiente local)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Suíte de testes (tests/setup/supabase-test.ts) — projeto Supabase SEPARADO,
# dedicado só a testes automatizados. NUNCA aponte estas variáveis para o
# projeto de produção acima: os testes fazem signUp/signIn reais em massa e
# esgotariam o rate limit de auth do projeto real.
TEST_SUPABASE_URL=
TEST_SUPABASE_ANON_KEY=
# Opcional: quando configurada, os testes criam a conta via admin.createUser
# (bypassa o rate limit de signup público do GoTrue). NUNCA usar NEXT_PUBLIC_
# nem expor no client — bypassa TODA policy RLS. Sem esta chave, os testes
# caem de volta no signUp público contra o projeto de teste (mais lento, mas
# ainda isolado de produção).
TEST_SUPABASE_SERVICE_ROLE_KEY=
